{
  "name": "@ankhorage/orchestrator-module-expo-localization",
  "version": "0.1.2",
  "description": "Expo localization module for @ankhorage/orchestrator.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/ankhorage/orchestrator-module-expo-localization#readme",
  "bugs": {
    "url": "https://github.com/ankhorage/orchestrator-module-expo-localization/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ankhorage/orchestrator-module-expo-localization.git"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "templates",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && bun x tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "test": "bun test",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "dependencies": {
    "@ankhorage/orchestrator": "^0.1.2"
  },
  "devDependencies": {
    "@ankhorage/devtools": "^1.0.1",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "knip": "^5.88.1",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.13",
  "publishConfig": {
    "access": "public"
  }
}
