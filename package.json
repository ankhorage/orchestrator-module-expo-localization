{
  "name": "@ankhorage/orchestrator-module-expo-localization",
  "version": "0.1.0",
  "description": "Expo localization module for @ankhorage/orchestrator.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && bun x tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test",
    "changeset": "changeset",
    "changeset:version": "changeset version"
  },
  "dependencies": {
    "@ankhorage/orchestrator": "^0.1.1"
  },
  "devDependencies": {
    "@ankhorage/devtools": "^1.0.0",
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.2.3",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.11",
  "publishConfig": {
    "access": "public"
  }
}
